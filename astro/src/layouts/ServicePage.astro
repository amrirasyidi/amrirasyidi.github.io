---
import '../styles/style.css';

interface Props {
  title: string;
  excerpt: string;
}

const { title, excerpt } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={excerpt} />
    <title>{title} - Amri Rasyidi</title>
  </head>
  <body class="wide-page">
    <div class="header">
      <nav class="nav">
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/services" class="active">Services</a>
          <a href="/blog">Blog</a>
          <a href="/tags">Tags</a>
        </div>
      </nav>
    </div>

    <div class="back-link">
      <a href="/services">← Back to Services</a>
    </div>

    <h1>{title}</h1>

    <div class="post-content">
      <slot />
    </div>

    <div class="cta-section">
      <h2>Ready to Start Your Project?</h2>
      <p>Let's discuss how this can work for your specific use case.</p>
      <div class="contact-options">
        <a href="/services#get-in-touch" class="primary-cta">Discuss This Service</a>
        <a href="/services" class="secondary-cta">← All Services</a>
      </div>
    </div>
  </body>
</html>
