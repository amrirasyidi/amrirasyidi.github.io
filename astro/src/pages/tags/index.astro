---
import { getCollection } from 'astro:content';
import '../../styles/style.css';

const posts = await getCollection('blog', ({ data }) => !data.draft);

// Build tag → post count map
const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  }
}

// Sort tags alphabetically
const sortedTags = [...tagCounts.entries()].sort((a, b) => a[0].localeCompare(b[0]));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Browse blog posts by tag" />
    <title>Tags - Amri Rasyidi</title>
  </head>
  <body>
    <div class="header">
      <nav class="nav">
        <div class="nav-links">
          <a href="/">Home</a>
          {import.meta.env.DEV && <a href="/services">Services</a>}
          <a href="/blog">Blog</a>
          <a href="/tags" class="active">Tags</a>
        </div>
      </nav>
    </div>

    <h1>Tags</h1>

    <p>Browse posts by topic. Click on any tag below to view posts from that category:</p>

    <div class="tag-cloud-grid" style="margin-top: 30px;">
      {sortedTags.map(([tag, count]) => (
        <a href={`/tags/${tag}`} class="tag">
          {tag} ({count})
        </a>
      ))}
    </div>
  </body>
</html>
